<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CommandString</key>
	<string>bash -c 'DIR=$(find "$HOME" \( -name "School-y" -o -name "School-y-main" \) -type d -maxdepth 5 2>/dev/null | head -1); if [ -z "$DIR" ]; then DIR=$(find "$HOME/Downloads" "$HOME/Desktop" "$HOME/Documents" -name "tunnel-start.sh" -maxdepth 4 2>/dev/null | head -1 | xargs dirname 2>/dev/null); fi; if [ -n "$DIR" ]; then cd "$DIR" && echo "Found School-y in: $DIR" && bash tunnel-start.sh; else echo "Could not find the School-y folder."; echo "Please drag the tunnel-start.sh file onto this window and press Enter."; exec bash; fi'</string>
	<key>ProfileCurrentVersion</key>
	<real>2.0600000000000001</real>
	<key>RunCommandAsShell</key>
	<false/>
	<key>name</key>
	<string>School-y Tunnel</string>
	<key>type</key>
	<string>Window Settings</string>
</dict>
</plist>
